---
permalink: /manifest.webmanifest
---
{
  "name": "{{ site.siteName }}",
  "short_name": "{{ site.brandName }}",
  "start_url": "{{ '/' | url }}",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "{{ site.themeColor }}",
  "lang": "ru",
  "icons": [
    {
      "src": "{{ '/assets/img/icon-192.png' | url }}",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "{{ '/assets/img/icon-512.png' | url }}",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
