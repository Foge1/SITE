---
pagination:
  data: services.items
  size: 1
  alias: service
permalink: false
eleventyComputed:
  permalink: "/{{ service.slug }}/index.html"
  title: "{{ service.title }}"
  description: "{{ service.description }}"
  canonicalPath: "{{ service.canonicalPath }}"
---
<!DOCTYPE html>
<html lang="ru">
{% include "head.njk" %}
<body>
{% include "header-nav.njk" %}
{% set isGoldenService = service.layout == 'golden' and service.landing %}
{% if isGoldenService %}
{% include "service-page-golden.njk" %}
{% else %}
{% include "service-page-content.njk" %}
{% include "geo-coverage.njk" %}
{% endif %}
{% set finalCtaData = service.finalCta %}
{% if isGoldenService and service.landing.finalCta %}
{% set finalCtaData = service.landing.finalCta %}
{% endif %}
{% set ctaTitleMain = finalCtaData.titleMain %}
{% set ctaTitleAccent = finalCtaData.titleAccent %}
{% set ctaSub = finalCtaData.subtitle %}
{% set ctaButtonLabel = finalCtaData.buttonLabel %}
{% include "cta.njk" %}
{% include "contact.njk" %}
{% include "footer.njk" %}
<script src="{{ '/assets/js/main.js' | url }}"></script>
</body>
</html>
