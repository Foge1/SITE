{%- set serviceHeroVariant = serviceHeroVariant or 'default' -%}
{%- if serviceHeroVariant == 'golden' -%}
  {%- set heroData = service.landing.hero -%}
  {%- set heroImageSrc = '/assets/img/hero.jpg' -%}
  {%- if service.slug == 'kvartirnyj-pereezd-voronezh' -%}
    {%- set heroImageSrc = '/assets/img/kvartirnyj-pereezd.webp' -%}
  {%- endif -%}
<section class="service-hero service-hero--golden">
  <div class="service-hero-left">
    <div class="service-hero-text">
      <div class="service-hero-breadcrumbs reveal">
        <a href="{{ '/' | url }}">Главная</a>
        <span>/</span>
        <span>{{ service.h1 }}</span>
      </div>
      <div class="service-hero-label-pill reveal rd1">{{ heroData.label }}</div>
      <h1 class="service-hero-title">
        <span class="service-hero-title-line">{{ heroData.title or service.h1 }}</span>
      </h1>
      <p class="service-hero-subtitle">{{ heroData.subtitle }}</p>
      <div class="service-hero-cta-row">
        <a href="#contact" class="btn-main"><span>{{ heroData.primaryCtaLabel }}</span></a>
        <a href="{{ heroData.secondaryCtaHref or ('/' | url) }}" class="btn-outline">{{ heroData.secondaryCtaLabel }}</a>
      </div>
      <ul class="service-hero-trust-list">
        {%- for item in heroData.trustBullets -%}
        <li class="service-hero-trust-item reveal rd{{ (loop.index0 % 4) + 1 }}">
          <span class="service-hero-trust-dot"></span>
          <span>{{ item }}</span>
        </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
  <div class="service-hero-right">
    <div class="service-hero-visual reveal rd2">
      <img class="service-hero-visual-image" src="{{ heroImageSrc | url }}" alt="{{ service.h1 }}">
      <div class="service-hero-visual-card">
        <span class="service-hero-visual-badge">{{ heroData.visualBadge }}</span>
        <h2 class="service-hero-visual-title">{{ heroData.visualTitle }}</h2>
        <ul class="service-hero-visual-list">
          {%- for point in heroData.visualPoints -%}
          <li>{{ point }}</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>
{%- else -%}
<section class="service-hero service-hero--default">
  <div class="service-hero-left">
    <div>
      <div class="service-hero-breadcrumbs reveal">
        <a href="{{ '/' | url }}">Главная</a>
        <span>/</span>
        <span>{{ service.h1 }}</span>
      </div>
      <div class="service-hero-eyebrow">
        <div class="service-hero-eyebrow-dot"></div>
        <span class="service-hero-eyebrow-text">{{ service.hero.eyebrow }}</span>
      </div>
      <h1 class="service-hero-title">
        <span class="service-hero-title-line">{{ service.h1 }}</span>
      </h1>
      <p class="service-hero-offer">{{ service.hero.offer }}</p>
      <p class="service-hero-desc">{{ service.hero.text }}</p>
      <div class="service-hero-cta-row">
        <a href="#contact" class="btn-main"><span>{{ service.hero.primaryCtaLabel }}</span></a>
        <a href="{{ '/' | url }}" class="btn-outline">{{ service.hero.secondaryCtaLabel }}</a>
      </div>
    </div>
    <div class="service-hero-stats-row">
      {%- for stat in service.hero.stats -%}
      <div class="service-hero-stat">
        <div class="service-hero-stat-big">{{ stat.value }}</div>
        <div class="service-hero-stat-sm">{{ stat.label }}</div>
      </div>
      {%- endfor -%}
    </div>
  </div>
  <div class="service-hero-right">
    <div class="service-hero-media">
      <img class="service-hero-media-image" src="{{ '/assets/img/hero.jpg' | url }}" alt="{{ service.h1 }}">
    </div>
    <div class="service-hero-facts">
      {%- for fact in service.hero.facts -%}
      <div class="service-hero-fact">
        <div class="service-hero-fact-label">{{ fact.label }}</div>
        <div class="service-hero-fact-value">{{ fact.value }}</div>
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
