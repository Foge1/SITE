<section class="contact" id="contact">
  <div class="sec-head reveal">
    <div>
      <div class="sec-label">Связаться</div>
      <h2 class="sec-title">Оставьте заявку</h2>
    </div>
    <p class="sec-sub">Перезвоним за 5 минут, обсудим задачу и назовём цену.</p>
  </div>
  <div class="contact-body">
    <div class="contact-info reveal">
      <div class="ci-row"><span class="ci-label">Телефон</span><a class="ci-val" href="tel:{{ site.phoneHref }}">{{ site.phoneDisplay }}</a></div>
      <div class="ci-row"><span class="ci-label">Telegram</span><a class="ci-val" href="{{ site.social.telegram }}" target="_blank" rel="noopener">{{ site.phoneDisplay }}</a></div>
      <div class="ci-row"><span class="ci-label">Работаем</span><span class="ci-val">{{ site.workHours }}</span></div>
      <div class="ci-row"><span class="ci-label">Район</span><span class="ci-val">{{ site.serviceArea }}</span></div>
    </div>
    <form action="/send.php" method="post" id="contact-form">
      <div class="contact-form reveal rd2">
        <div class="field-wrap" aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;opacity:0;height:0;overflow:hidden">
          <label for="website">Не заполняйте</label>
          <input type="text" name="website" id="website" tabindex="-1" autocomplete="off">
        </div>
        <div class="field-wrap">
          <input type="text" name="name" placeholder="Ваше имя">
        </div>

        <div class="field-wrap">
          <input type="tel" name="phone" placeholder="Телефон для связи" required>
        </div>

        <div class="field-wrap">
          <select name="service" required>
            <option value="" disabled selected>Что нужно сделать?</option>
            <option>Помощь на час</option>
            <option>Газель с бригадой</option>
            <option>Квартирный переезд</option>
            <option>Офисный переезд</option>
            <option>Дача и пригород</option>
            <option>Вывоз мусора / старой мебели</option>
            <option>Другое</option>
          </select>
        </div>

        <div class="field-wrap">
          <input type="text" name="address" placeholder="Адрес (откуда)">
        </div>

        <div class="field-wrap">
          <textarea name="comment" rows="4" placeholder="Что везём, сколько этажей, есть ли лифт..."></textarea>
        </div>

        <button class="submit-btn" type="submit">Отправить заявку</button>
        <div class="form-message" id="form-message" aria-live="polite"></div>
      </div>
    </form>
  </div>
  </div>
</section>
