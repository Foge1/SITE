{% macro renderServiceIcon(slug) -%}
  {% if slug == 'gazel-s-gruzchikami-voronezh' %}
  <svg class="svc-icon" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <rect x="1" y="10" width="18" height="11" rx="1"/>
    <path d="M19 14h5l3 4v3H19V14z"/>
    <circle cx="6" cy="23" r="2.2"/>
    <circle cx="23" cy="23" r="2.2"/>
    <path d="M4 10V7h10v3"/>
  </svg>
  {% elif slug == 'kvartirnyj-pereezd-voronezh' %}
  <svg class="svc-icon" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <rect x="2" y="4" width="10" height="10" rx="1"/>
    <rect x="16" y="4" width="10" height="10" rx="1"/>
    <path d="M2 19h24M8 19v6M20 19v6M4 25h20"/>
  </svg>
  {% elif slug == 'ofisnyj-pereezd-voronezh' %}
  <svg class="svc-icon" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <rect x="3" y="7" width="22" height="15" rx="1"/>
    <path d="M9 7V4h10v3M3 15h22"/>
    <rect x="11" y="18" width="6" height="4"/>
  </svg>
  {% elif slug == 'vyvoz-musora-voronezh' %}
  <svg class="svc-icon" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <path d="M4 22h20M7 22V10l7-6 7 6v12"/>
    <path d="M5 10l9-7 9 7"/>
    <rect x="11" y="15" width="6" height="7"/>
  </svg>
  {% else %}
  <svg class="svc-icon" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <rect x="5" y="5" width="18" height="18" rx="2"/>
    <path d="M9 14h10M14 9v10"/>
  </svg>
  {% endif %}
{%- endmacro %}

<section class="services" id="services">
  <div class="sec-head reveal">
    <div>
      <div class="sec-label">Что мы делаем</div>
      <h2 class="sec-title">Услуги</h2>
    </div>
    <p class="sec-sub">Выберите нужный формат и перейдите на подробную страницу услуги.</p>
  </div>
  <div class="services-grid">
    {%- for item in services.serviceCards -%}
    <a href="{{ item.path | url }}" class="service-card service-card-link reveal rd{{ (loop.index0 % 4) + 1 }}">
      <div class="svc-icon-wrap">{{ renderServiceIcon(item.slug) }}</div>
      <div class="svc-name">{{ item.name }}</div>
      <p class="svc-text">{{ item.homeText }}</p>
      <div class="svc-price">Перейти на страницу услуги</div>
    </a>
    {%- endfor -%}
  </div>
</section>
