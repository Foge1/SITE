{%- set landing = service.landing -%}
{%- set serviceHeroVariant = 'golden' -%}
{%- set sectionsMeta = landing.sections or {} -%}
{%- set sectionOrder = landing.sectionOrder or ['advantages', 'includes', 'scenarios', 'process', 'pricing', 'faq'] -%}
{% include "service-hero.njk" %}

{% macro renderSectionHead(meta, defaultLabel, defaultTitle, defaultSubtitle, titleId) -%}
  {%- set head = meta or {} -%}
  <div class="sec-head reveal">
    <div>
      <div class="sec-label">{{ head.label or defaultLabel }}</div>
      <h2 class="sec-title" id="{{ titleId }}">{{ head.title or defaultTitle }}</h2>
    </div>
    <p class="sec-sub">{{ head.subtitle or defaultSubtitle }}</p>
  </div>
{%- endmacro %}

{%- for section in sectionOrder -%}
  {%- if section == 'advantages' and landing.advantages and landing.advantages.length -%}
<section class="service-block" id="why" aria-labelledby="service-adv-title">
  {{ renderSectionHead(
    sectionsMeta.advantages,
    'Ключевые преимущества',
    'ЗА ЧТО НАС ВЫБИРАЮТ',
    'Коротко о том, что важно для спокойного переезда.',
    'service-adv-title'
  ) }}
  <div class="service-adv-grid">
    {%- for item in landing.advantages -%}
    <article class="service-adv-card reveal rd{{ (loop.index0 % 4) + 1 }}">
      <h3 class="service-adv-title">{{ item.title }}</h3>
      <p class="service-adv-text">{{ item.text }}</p>
    </article>
    {%- endfor -%}
  </div>
</section>
  {%- elif section == 'includes' and landing.includes and landing.includes.length -%}
<section class="service-block" id="services" aria-labelledby="service-includes-title">
  {{ renderSectionHead(
    sectionsMeta.includes,
    'Что входит в услугу',
    'ЧТО ВХОДИТ В РАБОТУ',
    'Четкий набор работ без «додумываний» по ходу.',
    'service-includes-title'
  ) }}
  <div class="service-include-panel reveal">
    <ul class="service-include-list">
      {%- for item in landing.includes -%}
      <li class="service-include-item">
        <span class="service-check-mark" aria-hidden="true"></span>
        <span>{{ item }}</span>
      </li>
      {%- endfor -%}
    </ul>
  </div>
</section>
  {%- elif section == 'scenarios' and landing.scenarios and landing.scenarios.length -%}
<section class="service-block" aria-labelledby="service-scenarios-title">
  {{ renderSectionHead(
    sectionsMeta.scenarios,
    'Когда услуга подходит',
    'ТИПОВЫЕ СЦЕНАРИИ',
    'Ситуации, где важны скорость, аккуратность и понятный порядок работ.',
    'service-scenarios-title'
  ) }}
  <div class="service-scenarios-grid">
    {%- for item in landing.scenarios -%}
    <article class="service-scenario-card reveal rd{{ (loop.index0 % 4) + 1 }}">
      <h3 class="service-scenario-title">{{ item.title }}</h3>
      <p class="service-scenario-text">{{ item.text }}</p>
    </article>
    {%- endfor -%}
  </div>
</section>
  {%- elif section == 'process' and landing.steps and landing.steps.length -%}
<section class="process" id="process" aria-labelledby="service-process-title">
  {{ renderSectionHead(
    sectionsMeta.process,
    'Как мы работаем',
    'ПРОСТОЙ ПОНЯТНЫЙ ПРОЦЕСС',
    'Четыре шага от звонка до завершенного переезда.',
    'service-process-title'
  ) }}
  <div class="process-grid">
    {%- for step in landing.steps -%}
    <div class="process-step reveal rd{{ (loop.index0 % 4) + 1 }}">
      <div class="ps-num">0{{ loop.index }}</div>
      <div class="ps-title">{{ step.title }}</div>
      <p class="ps-text">{{ step.text }}</p>
    </div>
    {%- endfor -%}
  </div>
</section>
  {%- elif section == 'pricing' and landing.pricing and landing.pricing.factors and landing.pricing.factors.length -%}
<section class="service-pricing-compact" aria-labelledby="service-pricing-title">
  {{ renderSectionHead(
    sectionsMeta.pricing,
    'Стоимость',
    'ОТ ЧЕГО ЗАВИСИТ РАСЧЕТ',
    'Только реальные параметры, без выдуманных тарифов.',
    'service-pricing-title'
  ) }}
  <div class="service-pricing-body reveal">
    <p class="service-pricing-lead">{{ landing.pricing.lead }}</p>
    <div class="service-pricing-grid">
      {%- for factor in landing.pricing.factors -%}
      <article class="service-pricing-item">
        <h3 class="service-pricing-item-title">{{ factor.title }}</h3>
        <p class="service-pricing-item-text">{{ factor.text }}</p>
      </article>
      {%- endfor -%}
    </div>
    {%- if landing.pricing.note -%}
    <p class="service-pricing-note">{{ landing.pricing.note }}</p>
    {%- endif -%}
  </div>
</section>
  {%- elif section == 'faq' and landing.faq and landing.faq.length -%}
<section class="service-faq service-faq-compact" aria-labelledby="service-faq-title">
  {{ renderSectionHead(
    sectionsMeta.faq,
    'FAQ',
    'КОРОТКИЕ ОТВЕТЫ ПО ДЕЛУ',
    'То, что обычно спрашивают перед оформлением заявки.',
    'service-faq-title'
  ) }}
  <div class="service-faq-grid">
    {%- for item in landing.faq -%}
    <article class="service-faq-item reveal rd{{ (loop.index0 % 4) + 1 }}">
      <h3 class="service-faq-question">{{ item.question }}</h3>
      <p class="service-faq-answer">{{ item.answer }}</p>
    </article>
    {%- endfor -%}
  </div>
</section>
  {%- elif section == 'geo' -%}
{% include "geo-coverage.njk" %}
  {%- endif -%}
{%- endfor -%}

{%- set currentService = service -%}
{%- set relatedSectionMeta = sectionsMeta.links or {} -%}
{% include "service-context-links.njk" %}
{% include "related-services.njk" %}

{%- if landing.faq and landing.faq.length -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in landing.faq -%}
    {
      "@type": "Question",
      "name": {{ item.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
